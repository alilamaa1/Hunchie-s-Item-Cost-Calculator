    "start": "electron .",
    "test:backend": "node --test \"tests/backend/**/*.test.mjs\""
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "lucide-react": "^0.546.0",
    "pdfjs-dist": "^6.1.200",
    "pngjs": "^7.0.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "wait-on": "^9.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4"
  },
  "allowScripts": {}
}
