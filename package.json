{
  "name": "item-cost-calculator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "src/electron/main/main.mjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "cross-env NODE_ENV=development concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && electron .\"",
